# ================================================
# static.mreshank.com — Environment Configuration
# ================================================
# Copy this file to .env.local and fill in all values.
# On Vercel, set these in Project Settings > Environment Variables.

# ======================
# Storage — Vercel Blob
# ======================
# Get from: Vercel Dashboard > Storage > Blob > Tokens
STATIC_BLOB_READ_WRITE_TOKEN=

# ======================
# Database / KV — Upstash Redis (via Vercel KV)
# ======================
# Get from: Upstash Console > REST API section
# Or: Vercel Dashboard > Storage > KV Store > .env.local tab
STATIC_KV_REST_API_URL=
STATIC_KV_REST_API_TOKEN=

# ======================
# Authentication — Clerk
# ======================
# Get from: https://dashboard.clerk.com > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk routing configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# ======================
# App Configuration
# ======================
NEXT_PUBLIC_CDN_BASE=https://static.mreshank.com
MAX_FILE_SIZE_MB=500
